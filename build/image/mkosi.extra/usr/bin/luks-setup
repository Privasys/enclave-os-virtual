#!/bin/bash
# luks-setup — LUKS encryption for the Enclave OS (Virtual) data partition.
#
# Run by luks-data.service before data.mount.
#
# Key sources, in order:
#
#   vault — the default for pre-approved enclaves. `manager-bootstrap dek`
#     resolves the DEK from the Enclave Vaults constellation: on first boot
#     it redeems the `bootstrap-token` instance metadata (single-use,
#     quote-gated) and creates the key as k-of-n Shamir shares; on reboots
#     it reconstructs from the constellation, located via a non-secret
#     LUKS2 header token that travels with the disk. The DEK never exists
#     outside TEE memory and no key material sits in instance metadata.
#
#   byok — legacy. The operator sets the LUKS passphrase as an instance
#     metadata attribute named `luks-passphrase` (GCP), an instance tag of
#     the same name (AWS IMDSv2), or an Azure compute tag of the same name.
#
# The script fails hard when neither source yields a key, on every boot.
# Auto-generation is intentionally not supported: a random key kept only
# in RAM bricks the partition on the next reboot.
#
# On first boot the partition is formatted with LUKS2 + ext4 with
# per-sector dm-integrity tags (AES-XTS + HMAC-SHA256). On subsequent
# boots the existing LUKS volume is unlocked.
#
# Note on integrity choice: cryptsetup's --integrity aead requires an
# AEAD-native cipher (e.g. aes-gcm-random) and is incompatible with
# aes-xts-plain64. We use --integrity hmac-sha256 which gives the same
# security property (per-4K-sector authenticated encryption via
# dm-integrity) while keeping AES-NI/VAES-accelerated XTS for
# throughput. Do not switch to aes-gcm-random without a benchmark.
#
# Outputs:
#   /run/luks/dek-origin   key origin string for OID 2.6:
#                          "vault:<handle>" or "byok:<fingerprint>"
#   /run/luks/key-source   "vault" or "byok"
#   /dev/mapper/data-crypt the unlocked block device

set -euo pipefail

MAPPER="data-crypt"
LUKS_DIR="/run/luks"
ORIGIN_FILE="${LUKS_DIR}/dek-origin"
KEY_SOURCE_FILE="${LUKS_DIR}/key-source"

mkdir -p "$LUKS_DIR"

# ── 0. Discover the /data block device ───────────────────────────────────
#
# Preferred (since v0.4.0): a dedicated cloud persistent disk attached as
# device-name=data, which surfaces as /dev/disk/by-id/google-data on GCE
# (and equivalent stable-name links on other clouds via udev).
#
# Legacy fallback: /dev/disk/by-partlabel/data — a 1M (since v0.4.0) or
# 2G (pre-v0.4.0) partition on the boot disk. Used only by VMs that have
# not yet been migrated to the dedicated-PD layout.
#
# Both paths are populated asynchronously by udev after networkd brings
# the disk online. Wait briefly for either to appear.

discover_data_device() {
    local candidates=(
        /dev/disk/by-id/google-data
        /dev/disk/by-partlabel/data
    )
    local d
    for d in "${candidates[@]}"; do
        if [ -b "$d" ]; then
            printf '%s' "$d"
            return 0
        fi
    done
    return 1
}

PART=""
for attempt in $(seq 1 30); do
    if PART=$(discover_data_device); then
        break
    fi
    sleep 1
done
if [ -z "$PART" ]; then
    echo "luks-setup: ERROR — no /data device found" >&2
    echo "luks-setup: looked for /dev/disk/by-id/google-data and /dev/disk/by-partlabel/data" >&2
    exit 1
fi
case "$PART" in
    /dev/disk/by-id/google-data)
        echo "luks-setup: using dedicated /data PD ($PART)"
        ;;
    /dev/disk/by-partlabel/data)
        echo "luks-setup: WARNING legacy /data on boot disk ($PART) — migrate to a dedicated PD"
        ;;
esac

# ── 1. Resolve the DEK ───────────────────────────────────────────────────
#
# luks-data.service is ordered After=network-online.target, but DNS and
# metadata DHCP options can still take a few hundred ms to settle after
# networkd reports online. The shared provisioning-secret.sh library
# probes systemd-creds first (bare-metal QEMU / OVH) then GCP, AWS,
# Azure metadata.

# shellcheck disable=SC1091
source /usr/lib/enclave-os/provisioning-secret.sh

# 1a. Vault-backed (pre-approved enclaves). Surface the bootstrap token to
# the binary through the multi-cloud secret library (it falls back to GCE
# metadata itself). Exit 3 = not vault-managed, fall through to BYOK; any
# other failure is fatal — never guess a key.
BOOTSTRAP_TOKEN=$(read_provisioning_secret_retry bootstrap-token 2 1) || BOOTSTRAP_TOKEN=""
export BOOTSTRAP_TOKEN

PASSPHRASE=""
KEY_SOURCE=""
set +e
PASSPHRASE=$(/usr/sbin/manager-bootstrap dek --device "$PART")
rc=$?
set -e
unset BOOTSTRAP_TOKEN
if [ "$rc" -eq 0 ] && [ -n "$PASSPHRASE" ]; then
    KEY_SOURCE="vault"
    echo "luks-setup: using vault-backed DEK ($(cat "$ORIGIN_FILE" 2>/dev/null || echo 'vault'))"
    # manager-bootstrap wrote /run/luks/dek-origin + key-source itself.
elif [ "$rc" -ne 3 ]; then
    echo "luks-setup: ERROR — vault DEK resolution failed (rc=$rc); refusing to fall back" >&2
    exit 1
fi

# 1b. BYOK fallback (legacy volumes).
if [ -z "$PASSPHRASE" ]; then
    if PASSPHRASE=$(read_provisioning_secret_retry luks-passphrase 5 2); then
        :
    fi
    if [ -z "$PASSPHRASE" ]; then
        echo "luks-setup: ERROR — no vault-backed DEK and no LUKS passphrase found via systemd-creds or cloud metadata" >&2
        echo "luks-setup: pre-approve the enclave (bootstrap-token) or set 'luks-passphrase' and retry" >&2
        exit 1
    fi
    KEY_SOURCE="byok"
    echo "luks-setup: using BYOK passphrase from instance metadata"
    echo "byok" > "$KEY_SOURCE_FILE"

    # ── 2. Persist DEK origin (for OID 2.6) ──────────────────────────────
    FINGERPRINT=$(printf '%s' "$PASSPHRASE" | sha256sum | awk '{print $1}')
    echo "byok:${FINGERPRINT}" > "$ORIGIN_FILE"
    chmod 644 "$ORIGIN_FILE"
fi

# ── 3. Format or open ────────────────────────────────────────────────────

if cryptsetup isLuks "$PART" 2>/dev/null; then
    echo "luks-setup: opening existing LUKS volume"
    printf '%s' "$PASSPHRASE" | cryptsetup luksOpen "$PART" "$MAPPER" --key-file=-
else
    echo "luks-setup: formatting new LUKS2 volume"

    # dm-integrity + hmac are needed for LUKS2 per-sector integrity but
    # are not auto-loaded by the kernel. Load them explicitly before
    # format. Also covered by /etc/modules-load.d/crypto.conf for early
    # boot, but a defensive modprobe here is cheap.
    modprobe dm-integrity 2>/dev/null || true
    modprobe authenc     2>/dev/null || true

    printf '%s' "$PASSPHRASE" | cryptsetup luksFormat \
        --type luks2 \
        --cipher aes-xts-plain64 \
        --key-size 512 \
        --hash sha256 \
        --integrity hmac-sha256 \
        --iter-time 2000 \
        --batch-mode \
        --key-file=- \
        "$PART"

    printf '%s' "$PASSPHRASE" | cryptsetup luksOpen "$PART" "$MAPPER" --key-file=-

    # Vault mode: stamp the non-secret DEK locator into the LUKS2 header
    # (token id 7) so every future boot can find the constellation from
    # the disk alone. Written by `manager-bootstrap dek` on first boot.
    if [ "$KEY_SOURCE" = "vault" ]; then
        if [ ! -f /run/enclave/luks-token.json ]; then
            echo "luks-setup: ERROR — vault mode but no locator at /run/enclave/luks-token.json" >&2
            exit 1
        fi
        cryptsetup token import --token-id 7 --json-file /run/enclave/luks-token.json "$PART"
        echo "luks-setup: vault DEK locator imported into LUKS2 header (token 7)"
    fi

    echo "luks-setup: creating ext4 filesystem on /dev/mapper/$MAPPER"
    mkfs.ext4 -L data "/dev/mapper/$MAPPER"
fi

# Best-effort scrub.
PASSPHRASE=""

echo "luks-setup: /dev/mapper/$MAPPER ready"
