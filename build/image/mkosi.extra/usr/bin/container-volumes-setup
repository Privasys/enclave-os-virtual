#!/bin/bash
# container-volumes-setup — initialise LVM on the containers partition.
#
# Run once by container-volumes.service AFTER local-fs.target.
#
# This script:
#   1. Checks if the "containers" partition exists (by-partlabel).
#   2. Creates an LVM Physical Volume (PV) if not already initialised.
#   3. Creates the "containers" Volume Group (VG).
#
# Individual per-container Logical Volumes are created dynamically by the
# manager when a container is loaded with storage={size}.
set -euo pipefail

# Prefer a dedicated attached PD (device-name=containers, surfaced by GCE
# at /dev/disk/by-id/google-containers). It survives enclave IMAGE
# UPGRADES, which replace the boot disk and therefore wipe the in-image
# boot-disk 'containers' partition along with every per-container volume.
# Fall back to that partition for VMs provisioned without the PD.
if [ -b /dev/disk/by-id/google-containers ]; then
    PART="/dev/disk/by-id/google-containers"
else
    PART="/dev/disk/by-partlabel/containers"
fi
VG="containers"

# ── 0. Provision a writable LVM_SYSTEM_DIR on tmpfs ───────────────────────
# The root filesystem is read-only erofs in production, so LVM cannot write
# its archive/backup under /etc/lvm. We mirror /etc/lvm onto /run/lvm-conf
# and override backup_dir/archive_dir to point at /run/lvm/{backup,archive}.
# The manager's volume package sets LVM_SYSTEM_DIR=/run/lvm-conf for every
# LVM invocation; we set it here too so this script's own LVM commands work.
export LVM_SYSTEM_DIR=/run/lvm-conf
mkdir -p /run/lvm-conf /run/lvm/archive /run/lvm/backup
if [ -f /etc/lvm/lvm.conf ]; then
    cp /etc/lvm/lvm.conf /run/lvm-conf/lvm.conf
fi
if [ -d /etc/lvm/profile ]; then
    cp -r /etc/lvm/profile /run/lvm-conf/profile
fi
cat > /run/lvm-conf/lvmlocal.conf <<'EOF'
backup {
    backup_dir = "/run/lvm/backup"
    archive_dir = "/run/lvm/archive"
}
EOF

# ── 0.5 Mount point for per-container volumes ─────────────────────────────
mkdir -p /run/containers

# ── 1. Partition check ───────────────────────────────────────────────────

if [ ! -b "$PART" ]; then
    echo "container-volumes-setup: no 'containers' partition found — skipping"
    echo "container-volumes-setup: per-container encrypted volumes are not available"
    exit 0
fi

RESOLVED=$(readlink -f "$PART")
echo "container-volumes-setup: found containers partition at $RESOLVED"

# ── 2. Check if VG already exists ───────────────────────────────────────

if vgs --noheadings -o vg_name "$VG" &>/dev/null; then
    echo "container-volumes-setup: VG '$VG' already exists — nothing to do"
    exit 0
fi

# ── 3. Create PV (idempotent — skipped if already a PV) ─────────────────

if ! pvs --noheadings -o pv_name "$RESOLVED" &>/dev/null; then
    echo "container-volumes-setup: creating PV on $RESOLVED"
    pvcreate -f "$RESOLVED"
fi

# ── 4. Create VG ────────────────────────────────────────────────────────

echo "container-volumes-setup: creating VG '$VG' on $RESOLVED"
vgcreate "$VG" "$RESOLVED"

echo "container-volumes-setup: VG '$VG' ready"
vgs "$VG"
