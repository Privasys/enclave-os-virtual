[Unit]
Description=Enclave OS (Virtual) — Workload Manager
Documentation=https://github.com/Privasys/enclave-os-virtual
After=containerd.service network-online.target data.mount luks-data.service
Requires=containerd.service
Wants=network-online.target

[Service]
Type=simple
RuntimeDirectory=manager/extensions
EnvironmentFile=-/data/manager.env
ExecStart=/usr/bin/manager serve \
    --ca-cert ${CA_CERT:-/data/ca.crt} \
    --ca-key ${CA_KEY:-/data/ca.key} \
    --attestation-backend tdx \
    --caddy-listen :443 \
    --extensions-dir /run/manager/extensions \
    --machine-name %H \
    --hostname ${HOSTNAME_SUFFIX} \
    --dek-origin-file /run/luks/dek-origin \
    --oidc-issuer ${OIDC_ISSUER} \
    --oidc-audience ${OIDC_AUDIENCE:-enclave-os-virtual} \
    --oidc-manager-role ${OIDC_MANAGER_ROLE:-enclave-os-virtual:manager} \
    --oidc-monitoring-role ${OIDC_MONITORING_ROLE:-enclave-os-virtual:monitoring} \
    --log-level info
Restart=on-failure
RestartSec=5

# Security hardening.
NoNewPrivileges=yes
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes

# Logging.
StandardOutput=journal
StandardError=journal
SyslogIdentifier=manager

[Install]
WantedBy=multi-user.target
