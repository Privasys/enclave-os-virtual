# Pin the patched cvm-images kernel ABI (6.17.0-23-generic) and block any
# newer Ubuntu HWE kernel from being installed alongside it.
#
# Why: nvidia-driver-595-server-open and various other Recommends pull in
# the latest linux-image-generic-hwe-24.04 metapackage, which ends up
# installing a different ABI alongside ours. mkosi's grub then picks the
# *newest* kernel as the boot entry, but the core Ubuntu kernel does NOT
# include our cvm-guard / BadAML patch and (more visibly) ships a different
# module set whose `gve` driver mismatches the running kernel ABI - so on
# first boot there's no NIC, no metadata server, no SSH, no startup
# script, nothing.
#
# This pin keeps the boot kernel deterministic at the exact ABI shipped in
# build/kernel/debs/ from the cvm-images kernel-v* GitHub release.
#
# When cvm-images bumps the kernel ABI, update both:
#   1. The version numbers below.
#   2. The explicit linux-modules-nvidia-595-server-open-<abi> package in
#      build/image-gpu/mkosi.conf.

# Block the floating meta-packages that always resolve to the latest ABI.
Package: linux-image-generic-hwe-24.04 linux-headers-generic-hwe-24.04 linux-modules-nvidia-595-server-open-generic-6.17 linux-modules-nvidia-595-server-open-generic-hwe-24.04 linux-modules-nvidia-595-server-generic-6.17 linux-modules-nvidia-595-server-generic-hwe-24.04
Pin: release *
Pin-Priority: -1

# Prefer the locally-staged 595.58.03 nvidia binary set (downloaded
# into PackageDirectories=../kernel/debs by the GPU image workflow)
# over the noble-updates 595.71.05 set.
#
# Why: linux-modules-nvidia-595-server-open-6.17.0-23-generic depends on
# nvidia-kernel-common-595-server (<= 595.58.03-1) AND (>= 595.58.03),
# and the other nvidia-*-595-server user-space packages cross-depend on
# the matching common version (e.g. libnvidia-compute pulls
# `nvidia-kernel-common-595-server-595.71.05` virtual). To keep apt's
# resolver consistent we pin the entire family.
#
# Pin-Priority 1001 lets apt downgrade if necessary. Remove this once
# we bump cvm-images kernel to an ABI whose Ubuntu-signed open modules
# accept 595.71.05 (e.g. 6.17.0-29).
Package: nvidia-kernel-common-595-server libnvidia-cfg1-595-server libnvidia-common-595-server libnvidia-compute-595-server libnvidia-decode-595-server libnvidia-encode-595-server libnvidia-extra-595-server libnvidia-fbc1-595-server libnvidia-gl-595-server nvidia-compute-utils-595-server nvidia-utils-595-server
Pin: version 595.58.03-0ubuntu0.24.04.1
Pin-Priority: 1001
