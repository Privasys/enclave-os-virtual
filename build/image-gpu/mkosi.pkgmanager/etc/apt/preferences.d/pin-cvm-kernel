# Pin the patched cvm-images kernel ABI (6.17.0-23-generic) and block any
# newer Ubuntu HWE kernel from being installed alongside it.
#
# Why: nvidia-driver-595-server-open and various other Recommends pull in
# the latest linux-image-generic-hwe-24.04 metapackage, which ends up
# installing a different ABI alongside ours. mkosi's grub then picks the
# *newest* kernel as the boot entry, but the core Ubuntu kernel does NOT
# include our cvm-guard / BadAML patch and (more visibly) ships a different
# module set whose `gve` driver mismatches the running kernel ABI - so on
# first boot there's no NIC, no metadata server, no SSH, no startup
# script, nothing.
#
# This pin keeps the boot kernel deterministic at the exact ABI shipped in
# build/kernel/debs/ from the cvm-images kernel-v* GitHub release.
#
# When cvm-images bumps the kernel ABI, update both:
#   1. The version numbers below.
#   2. The explicit linux-modules-nvidia-595-server-open-<abi> package in
#      build/image-gpu/mkosi.conf.

# Block the floating meta-packages that always resolve to the latest ABI.
Package: linux-image-generic-hwe-24.04 linux-headers-generic-hwe-24.04 linux-modules-nvidia-595-server-open-generic-6.17 linux-modules-nvidia-595-server-open-generic-hwe-24.04
Pin: release *
Pin-Priority: -1

# Pin nvidia-kernel-common-595-server to the version compatible with our
# fixed linux-modules-nvidia-595-server-open-6.17.0-23-generic.
#
# Why: noble-updates bumped nvidia-kernel-common-595-server from
# 595.58.03-1 to 595.71.05-0ubuntu0.24.04.1 (2026-05) but the matching
# linux-modules-nvidia-* for ABI 6.17.0-23 stayed at 595.58.03-1 (our
# explicit `linux-modules-nvidia-595-server-open-6.17.0-23-generic` in
# mkosi.conf has `Depends: nvidia-kernel-common-595-server (<= 595.58.03-1)`).
# Without this pin apt picks the newer common pkg and the install fails:
#   "linux-modules-nvidia-595-server-open-6.17.0-23-generic : Depends:
#    nvidia-kernel-common-595-server (<= 595.58.03-1) but 595.71.05-... is
#    to be installed".
#
# Remove this pin when bumping the linux-modules-nvidia-* pinned version
# in mkosi.conf to one that allows the newer common pkg.
Package: nvidia-kernel-common-595-server
Pin: version 595.58.03*
Pin-Priority: 1001
